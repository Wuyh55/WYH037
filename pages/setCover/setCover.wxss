page {
  background: #fff8e6;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}
.wrap {
  width: 100%;
}
.head {
  text-align: center;
  margin-bottom: 60rpx;
}
.main-title {
  display: block;
  font-size: 44rpx;
  color: #8c6d31;
  margin-bottom: 20rpx;
}
.sub-title {
  font-size: 32rpx;
  color: #a89882;
}
.select-area {
  margin-bottom: 30rpx;
}
.label {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.picker-box {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border: 1rpx solid #e2d4bf;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}
.picker-box::after {
  content: "∨";
  font-size: 36rpx;
  color: #8c6d31;
}
.preview-selected {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.preview-label {
  display: block;
  font-size: 28rpx;
  color: #8c6d31;
  margin-bottom: 16rpx;
}
.preview-img {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}
.save-btn {
  width: 100%;
  height: 100rpx;
  background: #b89668;
  color: #fff;
  border-radius: 14rpx;
  font-size: 34rpx;
  border: none;
  margin-bottom: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
}
.divider {
  width: 100%;
  height: 1rpx;
  background: #e2d4bf;
  margin-bottom: 60rpx;
}
.preview-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  color: #8c6d31;
  margin-bottom: 40rpx;
}
.img-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}
.img-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: all 0.3s;
}
.img-item.selected {
  border: 4rpx solid #b89668;
  box-shadow: 0 6rpx 20rpx rgba(184, 150, 104, 0.3);
}
.img-item image {
  width: 100%;
  height: 260rpx;
}
.img-name {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 0;
}
.check-mark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: #b89668;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}