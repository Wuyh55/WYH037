.page-login {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background: #fff9ef;
  padding: 120rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-avatar {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 30rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(184, 140, 100, 0.2);
}

.avatar-img {
  width: 100%;
  height: 100%;
  background: #f3e9dd;
}

.title {
  display: block;
  text-align: center;
  font-size: 42rpx;
  font-weight: bold;
  color: #665444;
  margin-bottom: 60rpx;
  letter-spacing: 4rpx;
}

.error-tip {
  color: #e64340;
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 28rpx;
  background: #fef0ef;
  padding: 16rpx 30rpx;
  border-radius: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  width: 100%;
  margin-bottom: 36rpx;
}

.label {
  font-size: 30rpx;
  color: #887666;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-wrap {
  width: 100%;
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: transparent;
  border: none;
  outline: none;
}

.captcha-wrap {
  display: flex;
  gap: 20rpx;
  align-items: center;
  width: 100%;
}

.captcha-input-wrap {
  flex: 1;
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.captcha-input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: transparent;
  border: none;
  outline: none;
}

.captcha-img {
  width: 240rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #ffffff;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0e8de;
  /* 新增居中文字代码 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  color: #333;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #b88c64 0%, #a07854 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(184, 140, 100, 0.3);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.register-link {
  text-align: center;
  font-size: 28rpx;
  color: #887666;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.link {
  color: #b88c64;
  font-weight: 500;
  text-decoration: underline;
  padding: 10rpx 20rpx;
}