page {
  background: #fff8e6;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}
/* 标题 */
.title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #8c6d31;
  margin-bottom: 40rpx;
  font-weight: 500;
}
/* 文本域输入框，文字垂直居中 */
.inp {
  width: 100%;
  border: 1rpx solid #e2d4bf;
  border-radius: 14rpx;
  padding: 24rpx;
  font-size: 30rpx;
  background: #fff;
  box-sizing: border-box;
  margin-bottom: 60rpx;
}
.inp::placeholder {
  color: #b9a88c;
}
/* 按钮容器 */
.btns {
  display: flex;
  gap: 40rpx;
  justify-content: center;
}
/* 按钮统一居中方案，清除原生button内边距 */
.btn-gray, .btn-main {
  width: 220rpx;
  height: 80rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: opacity 0.2s;
}
.btn-gray:active, .btn-main:active {
  opacity: 0.8;
}
.btn-gray {
  background: #e8ddcb;
  color: #8c6d31;
}
.btn-main {
  background: #b89668;
  color: #fff;
}