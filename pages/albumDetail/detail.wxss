page {
  background: #fff8e6;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
}
/* 相册头部区域 */
.detail-header {
  margin-bottom: 60rpx;
}
.title {
  font-size: 48rpx;
  color: #8c6d31;
  display: block;
  font-weight: 500;
}
.create-time {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin: 10rpx 0;
}
/* 相册简介卡片 */
.album-desc {
  font-size: 30rpx;
  color: #666;
  margin: 20rpx 0;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
}
/* 顶部功能按钮导航栏 */
.btn-group {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 16rpx;
  margin-top: 20rpx;
}
.btn-group button {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  background: #b89668;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  margin: 0;
}
.btn-group .del-btn {
  background: #dd6b6b;
}

/* 图片3列网格 */
.img-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 40rpx;
}
.img-item {
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
}
.img-item image {
  width: 100%;
  height: 240rpx;
}
.img-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 16rpx 0;
}
.img-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 16rpx 16rpx;
}
/* 空相册提示文字 */
.empty-album-tip {
  text-align: center;
  margin-top: 120rpx;
  font-size: 32rpx;
  color: #b9a88c;
}

/* ========== 全屏图片预览样式 ========== */
/* 黑色遮罩层 */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #000000;
  z-index: 9999;
}
.preview-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}
.swiper-box {
  flex: 1;
  width: 100%;
}
.big-img {
  width: 100%;
  height: 100%;
}
/* 右上角关闭X */
.close-preview {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  font-size: 64rpx;
  color: #fff;
  z-index: 99999;
}
/* 底部图片备注文字 */
.preview-desc {
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx 0;
}
/* 底部三个操作按钮三等分 */
/* 底部三个操作按钮三等分 */
.preview-op-btn {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  padding-bottom: 100rpx;
  width: 92%;
  margin: 0 auto;
}
.preview-op-btn button {
  flex: 1;
  height: 90rpx;
  background: #ffffff;
  color: #333;
  border-radius: 14rpx;
  font-size: 30rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  margin: 0;
}