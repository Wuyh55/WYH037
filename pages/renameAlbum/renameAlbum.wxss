page {
  background: #fff8e6;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}
/* 标题 */
.title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #8c6d31;
  margin-bottom: 40rpx;
  font-weight: 500;
}
/* 输入框 */
.inp {
  border: 1rpx solid #e2d4bf;
  border-radius: 14rpx;
  /* 上下左右统一内边距，垂直居中 */
  padding: 0 24rpx;
  line-height: 88rpx;
  height: 88rpx;
  font-size: 30rpx;
  background: #fff;
  box-sizing: border-box;
  margin-bottom: 45rpx;
}
.inp::placeholder {
  color: #b9a88c;
  line-height: 88rpx;
}
/* 按钮容器 */
.btns {
  display: flex;
  gap: 40rpx;
  justify-content: center;
}
/* 通用按钮基础 */
.btn-gray, .btn-main {
  width: 220rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 14rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
  margin: 0;
  transition: opacity 0.2s;
}
.btn-gray:active, .btn-main:active {
  opacity: 0.8;
}
.btn-gray {
  background: #e8ddcb;
  color: #8c6d31;
}
.btn-main {
  background: #b89668;
  color: #fff;
}