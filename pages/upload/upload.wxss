/* 页面底色和整套相册统一 */
page {
  background: #fff8e6;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 顶部标题区域 */
.page-title-wrap {
  text-align: center;
  margin-bottom: 60rpx;
}
.page-title {
  font-size: 44rpx;
  color: #8c6d31;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 内容容器统一间距 */
.upload-box {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 通用主按钮统一规范样式 */
.main-btn {
  width: 100%;
  height: 90rpx;
  background: #b89668;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
  /* 核心居中代码 */
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  margin: 0;
  /* 点击柔和反馈 */
  transition: opacity 0.2s;
}
.main-btn:active {
  opacity: 0.82;
}

/* ========== 新增：3列网格预览（替换原来横向滚动） ========== */
.file-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}
/* 单张预览缩略卡片 */
.file-item {
  width: 100%;
  height: 180rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  /* 轻微阴影分层，视觉柔和不突兀 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.file-item image {
  width: 100%;
  height: 100%;
  display: block;
}
/* 删除缩略图按钮优化 */
.del-file {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 38rpx;
  height: 38rpx;
  background: #e74c3c;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 38rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 统一描述输入框样式 */
.desc-input {
  width: 100%;
  height: 150rpx;
  background: #ffffff;
  border: 1rpx solid #e2d4bf;
  border-radius: 16rpx;
  padding: 26rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  color: #333;
}
/* 占位文字柔和配色 */
.desc-input::placeholder {
  color: #b9a88c;
}