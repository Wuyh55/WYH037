page {
  background: #fff8e6;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
  position: relative;
}

/* ========== 左上角头像 ========== */
.avatar-float {
  position: absolute;
  left: 20rpx;
  top: 30rpx;
  width: 100rpx;
  height: 100rpx;
  z-index: 99;
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(140, 109, 49, 0.18);
  background: #f3e9d7;
}

/* ========== 欢迎文字 ========== */
.welcome-top {
  width: 100%;
  text-align: center;
  margin: 0 0 40rpx;
  padding-left: 110rpx;
  box-sizing: border-box;
}
.welcome-text {
  font-size: 40rpx;
  color: #8c6d31;
  font-weight: 500;
  line-height: 100rpx;
}

/* ========== 导航栏：只保留搜索，占满整行 ========== */
.nav-bar {
  width: 100%;
  margin-bottom: 50rpx;
}
.search-full-bar {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  height: 76rpx;
}
.search-select {
  padding: 0 22rpx;
  height: 100%;
  line-height: 76rpx;
  font-size: 26rpx;
  border-right: 1rpx solid #eee;
  color: #666;
}
.search-input-wrap {
  flex: 1;
  padding: 0 18rpx;
}
.search-input {
  height: 76rpx;
  font-size: 28rpx;
}
.search-btn-box {
  width: 76rpx;
  height: 76rpx;
  background: #b89668;
  color: #fff;
  text-align: center;
  line-height: 76rpx;
  font-size: 32rpx;
}

/* 相册标题 */
.section-title {
  display: block;
  text-align: center;
  font-size: 44rpx;
  color: #8c6d31;
  margin: 30rpx 0 80rpx;
}

/* 空相册提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  color: #b9a88c;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 34rpx;
  line-height: 2;
}

/* 相册卡片网格 */
.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}
.album-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.album-cover-box {
  width: 100%;
  height: 320rpx;
}
.album-cover {
  width: 100%;
  height: 100%;
}
.album-info {
  padding: 20rpx;
}
.album-name {
  font-size: 30rpx;
  color: #555;
  display: block;
}
.album-time {
  font-size: 24rpx;
  color: #999;
  margin: 10rpx 0;
  display: block;
}
/* 单个按钮自动居中 */
.album-action-btns {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}
.album-action-btns text {
  font-size: 26rpx;
  color: #8c6d31;
  border: 1rpx solid #d4c3a8;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

/* 分页 */
.pagination {
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.page-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid #d4c3a8;
  border-radius: 8rpx;
  color: #8c6d31;
}
.page-btn.active {
  background: #b89668;
  color: #fff;
  border-color: #b89668;
}
.page-btn.disabled {
  opacity: 0.4;
}
.page-desc {
  margin-left: 30rpx;
  color: #8c6d31;
  font-size: 26rpx;
}